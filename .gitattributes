# Default: let Git decide text vs binary automatically
* text=auto

# =============================================================================
# Text files — enforce LF in the repository
# =============================================================================

# TypeScript / JavaScript
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf

# Rust source
*.rs    text eol=lf
*.toml  text eol=lf

# Web / config
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf

# Shell scripts
*.sh    text eol=lf

# Windows scripts
*.bat   text eol=crlf
*.cmd   text eol=crlf

# =============================================================================
# Binary files — prevent Git from mangling them
# =============================================================================

# WebAssembly binaries: never diff/merge as text
*.wasm  binary

# Common binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.zip   binary
*.gz    binary
*.tar   binary
